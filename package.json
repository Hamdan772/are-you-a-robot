{
  "name": "are-you-a-robot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/main.tsx --bundle --jsx=automatic --external:/public/* --outfile=app.js --servedir=. --serve=127.0.0.1:5173",
    "build": "tsc -b && mkdir -p dist/public && cp index.html dist/index.html && cp -R public/* dist/public/ && esbuild src/main.tsx --bundle --jsx=automatic --external:/public/* --minify --outfile=dist/app.js",
    "lint": "eslint .",
    "preview": "esbuild dist/app.js --servedir=dist --serve=127.0.0.1:4173"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  }
}
